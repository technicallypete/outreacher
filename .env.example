# Host port the MCP server is exposed on.
# Default is 3001 (dev). Set to 9000 to match the Claude Desktop config.
MCP_HOST_PORT=3001

# API keys — set whichever provider(s) you use for chat and MCP extraction.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# Chat model provider: "openai" (default) or "anthropic"
CHAT_LLM_PROVIDER=anthropic
# CHAT_LLM_MODEL=   # optional — defaults: openai→gpt-4o-mini, anthropic→claude-sonnet-4-6

# MCP server LLM provider for CSV extraction: "openai" (default) or "anthropic"
MCP_LLM_PROVIDER=openai
# MCP_LLM_MODEL=    # optional — defaults: openai→gpt-4o-mini, anthropic→claude-haiku-4-5

# Resend API key — used by NextAuth for magic link emails.
RESEND_API_KEY=re_...
RESEND_FROM=Outreacher <onboarding@resend.dev>   # or noreply@yourdomain.com once domain is verified

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=...
NEXTAUTH_URL=http://localhost:3000
